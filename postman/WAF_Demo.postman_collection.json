          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 403 (blocked by WAF)', function () {",
              "    pm.response.to.have.status(403);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "10) Time-based SQLi Payload (Blocked)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/search?q=1%27%3B%20WAITFOR%20DELAY%20%270%3A0%3A5%27--",
          "host": ["{{baseUrl}}"],
          "path": ["search"],
          "query": [
            {
              "key": "q",
              "value": "1'; WAITFOR DELAY '0:0:5'--"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 403 (blocked by WAF)', function () {",
              "    pm.response.to.have.status(403);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "11) Admin/Drop Payload (Blocked)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/search?q=admin%27%3B%20DROP%20TABLE%20users%3B--",
