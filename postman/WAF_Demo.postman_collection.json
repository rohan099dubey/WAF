            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "9) Command Injection Payload (Blocked)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/search?q=ping%20127.0.0.1%20%26%26%20system%20id",
          "host": ["{{baseUrl}}"],
          "path": ["search"],
          "query": [
            {
              "key": "q",
              "value": "ping 127.0.0.1 && system id"
